# Database
DATABASE_URL=postgresql://questboard:questboard@localhost:5432/questboard

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-32-chars-minimum-secret-key
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# S3 / R2
S3_BUCKET=questboard-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_BASE_URL=https://cdn.questboard.app

# Email
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@questboard.app

# App
PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
